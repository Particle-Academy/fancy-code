{
  "name": "@particle-academy/fancy-code",
  "version": "0.5.1",
  "description": "Lightweight embedded code editor with syntax highlighting and extensible language/theme registries",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-code.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-code#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-code/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "@particle-academy/react-fancy": ">=2",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@particle-academy/react-fancy": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "sideEffects": [
    "**/*.css",
    "src/languages/builtin.ts",
    "src/languages/index.ts",
    "src/engine/**/*.ts",
    "src/themes/light.ts",
    "src/themes/dark.ts",
    "src/themes/index.ts"
  ]
}
